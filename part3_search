# ─────────────────────────────────────────────────
#  PUBLIC API — called by Part 1
# ─────────────────────────────────────────────────
def attach_search_panel(app):
    """
    Inject the SearchPanel widget into app's header bar area.
    Call this once from part1_app_shell after editor is loaded.
    """
    panel = SearchPanel(app)
    # Add export button to header (Part 1 already built the header)
    _inject_header_buttons(app, panel)


# ─────────────────────────────────────────────────
#  HEADER BUTTON INJECTION
# ─────────────────────────────────────────────────
def _inject_header_buttons(app, panel):
    """Add Search and Export buttons into the existing header bar."""
    # Find the header frame (first child of app that is a Frame)
    for widget in app.winfo_children():
        if isinstance(widget, tk.Frame) and widget.cget("height") == 60:
            header = widget
            break
    else:
        return  # header not found

    # Export button
    tk.Button(
        header,
        text="📤  Export",
        bg=THEME["card"], fg=THEME["text"],
        font=FONTS["btn"], relief="flat", cursor="hand2",
        activebackground=THEME["card_hover"],
        activeforeground=THEME["text"],
        padx=10, pady=6,
        command=lambda: ExportDialog(app)
    ).pack(side="right", padx=6, pady=10)

    # Search button
    tk.Button(
        header,
        text="🔍  Search",
        bg=THEME["card"], fg=THEME["text"],
        font=FONTS["btn"], relief="flat", cursor="hand2",
        activebackground=THEME["card_hover"],
        activeforeground=THEME["text"],
        padx=10, pady=6,
        command=lambda: SearchDialog(app)
    ).pack(side="right", padx=0, pady=10)


